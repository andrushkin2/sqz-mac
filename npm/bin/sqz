#!/usr/bin/env node
// Thin wrapper — delegates to the downloaded sqz binary.
// This file is the npm bin entry point; the real binary is downloaded
// by install.js (postinstall) into the same directory as this file.

"use strict";

const path = require("path");
const fs = require("fs");
const { spawnSync } = require("child_process");

const ext = process.platform === "win32" ? ".exe" : "";
const binary = path.join(__dirname, `sqz${ext}`);

if (!fs.existsSync(binary)) {
  console.error(
    `sqz binary not found at ${binary}.\n` +
    `The postinstall step may have failed. Try:\n` +
    `  npm install -g sqz-cli --force\n` +
    `Or install via the shell script:\n` +
    `  curl -fsSL https://raw.githubusercontent.com/ojuschugh1/sqz/main/install.sh | sh`
  );
  process.exit(1);
}

const result = spawnSync(binary, process.argv.slice(2), { stdio: "inherit" });

if (result.error) {
  if (result.error.code === "ENOENT") {
    console.error(
      `sqz binary not found. Try reinstalling: npm install -g sqz-cli --force`
    );
  } else {
    console.error("Failed to run sqz:", result.error.message);
  }
  process.exit(1);
}

process.exit(result.status ?? 0);
